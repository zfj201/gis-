PORT=3300
HOST=0.0.0.0
ARCGIS_PARKS_LAYER_URL=https://www.geosceneonline.cn/server/rest/services/Hosted/%E7%A6%8F%E5%B7%9E%E5%B8%82%E5%85%AC%E5%9B%AD%E7%82%B9/FeatureServer/0
LAYER_REGISTRY_PATH=backend/data/layer-registry.json
LAYER_META_TIMEOUT_MS=8000
ALLOWED_LAYER_HOSTS=www.geosceneonline.cn,geosceneonline.cn
MAX_REGISTERED_SERVICES=20
DEFAULT_RADIUS_METERS=5000
# <=0 表示不限制查询半径
MAX_RADIUS_METERS=0

# semantic parser provider: rule | gemini | groq | openrouter
LLM_PROVIDER=gemini

# Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=12000

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=12000

# OpenRouter Free (OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
# comma-separated candidates; used when primary model fails
OPENROUTER_FALLBACK_MODELS=qwen/qwen3-4b:free,mistralai/mistral-7b-instruct:free
OPENROUTER_TIMEOUT_MS=12000
# Optional: for OpenRouter rankings / analytics
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=gis-semantic-query

# query pagination
QUERY_MAX_FEATURES=500000
QUERY_PAGE_SIZE=2000
QUERY_MAX_PAGES=2000

# nearest search
NEAREST_DEFAULT_K=1
NEAREST_MAX_K=100
NEAREST_INITIAL_RADIUS_METERS=500
NEAREST_MAX_RADIUS_METERS=100000
NEAREST_RADIUS_GROWTH_FACTOR=2
NEAREST_CANDIDATE_CAP=50000

# layer export
EXPORT_MAX_FEATURES=200000
EXPORT_PAGE_SIZE=1000
